OPENAI_API_KEY=
MODEL_NAME=gpt-4.1

# --- Daily-digest email (Gmail SMTP with an App Password) ---
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=matonte3@gmail.com
GMAIL_APP_PASSWORD= brwx qaxo zxjf obdr
# Where the digest's "open dashboard" links point (used in email templates).
DASHBOARD_BASE_URL=http://127.0.0.1:8000

# --- Daily job agent paths (override only if you need to) ---
# Defaults point under the repo root.
# OUTPUTS_DIR=
# PLAYWRIGHT_PROFILES_DIR=

# --- Job site credentials (OPTIONAL) ---
# These are used ONLY by scripts/login_once.py to pre-fill the login form
# during the one-time interactive sign-in. Day-to-day scraping uses the
# persistent browser profile cookie that login_once saves to .playwright/ -
# the password is never read by the daily scraper itself.
#
# You will still complete any 2FA / captcha yourself in the browser.
# All three are safe to leave blank; if blank, login_once just opens the
# sign-in page and waits for you to type credentials manually.
#
# Treat this file like any other password store: it's already in .gitignore,
# so nothing here leaves your machine.
LINKEDIN_EMAIL=matonte3@gmail.com
LINKEDIN_PASSWORD=

WTTJ_EMAIL=matonte3@gmail.com
WTTJ_PASSWORD=

JOBRIGHT_EMAIL=matonte3@gmail.com
JOBRIGHT_PASSWORD=

# --- Per-site profile overrides (OPTIONAL) ---
# Point Playwright at an existing browser user-data directory instead of
# the default .playwright/profile-<site>/ folder. Useful when a site's
# login flow refuses Playwright-driven Chromium and you need to reuse a
# session already established in your real browser.
#
# NOTE: the source browser (e.g. Chrome) must be CLOSED while the agent
# runs, or Chrome will refuse to start with "profile in use".
#
# Windows Chrome default is: %LOCALAPPDATA%\Google\Chrome\User Data
# (path expansion for %VARS% and ~ is handled automatically.)
WTTJ_PROFILE_DIR=
LINKEDIN_PROFILE_DIR=
JOBRIGHT_PROFILE_DIR=
