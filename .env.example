OPENAI_API_KEY=
MODEL_NAME=gpt-4.1

# --- Web sessions (sign-in / multi-user) ---
# Used to sign the session cookie. Set a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Browser/API default workspace when not logged in (built-in repo data/).
DEFAULT_USER_ID=1
# Windows Task Scheduler daily run: which user_id owns scraped jobs + artifacts.
DAILY_RUN_USER_ID=1

# --- New-account onboarding (résumé + job samples → profile JSON) ---
# ONBOARDING_MIN_RESUMES=1
# ONBOARDING_MIN_JOB_SAMPLES=3
# Local dev without OpenAI: save raw uploads under profile onboarding_sources/ and unlock the app.
# ONBOARDING_ALLOW_FINISH_WITHOUT_LLM=0

# --- Daily-digest email (Gmail SMTP with an App Password) ---
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
# Where the digest's "open dashboard" links point (used in email templates).
DASHBOARD_BASE_URL=http://127.0.0.1:8000

# --- Daily job agent paths (override only if you need to) ---
# Defaults point under the repo root. The production Dockerfile sets
# OUTPUTS_DIR=/data/outputs and PLAYWRIGHT_PROFILES_DIR=/data/playwright
# (mount a volume on /data in AWS/EC2).
# OUTPUTS_DIR=
# PLAYWRIGHT_PROFILES_DIR=
# Use installed Microsoft Edge instead of bundled Chromium (optional).
# With external LINKEDIN_PROFILE_DIR etc., set msedge if that path is Edge's
# user-data dir (%LOCALAPPDATA%\Microsoft\Edge\User Data on Windows).
# PLAYWRIGHT_CHANNEL=msedge

# --- Job site credentials (OPTIONAL) ---
# These are used ONLY by scripts/login_once.py to pre-fill the login form
# during the one-time interactive sign-in. Day-to-day scraping uses the
# persistent browser profile cookie that login_once saves to .playwright/ -
# the password is never read by the daily scraper itself.
#
# You will still complete any 2FA / captcha yourself in the browser.
# All three are safe to leave blank; if blank, login_once just opens the
# sign-in page and waits for you to type credentials manually.
#
# Treat this file like any other password store: it's already in .gitignore,
# so nothing here leaves your machine.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

WTTJ_EMAIL=
WTTJ_PASSWORD=

JOBRIGHT_EMAIL=
JOBRIGHT_PASSWORD=

# --- Per-site profile overrides (OPTIONAL) ---
# Point Playwright at an existing browser user-data directory instead of
# the default .playwright/profile-<site>/ folder. Useful when a site's
# login flow refuses Playwright-driven Chromium and you need to reuse a
# session already established in your real browser.
#
# NOTE: the source browser (e.g. Chrome) must be CLOSED while the agent
# runs, or Chrome will refuse to start with "profile in use".
#
# Windows Chrome default is: %LOCALAPPDATA%\Google\Chrome\User Data
# (path expansion for %VARS% and ~ is handled automatically.)
WTTJ_PROFILE_DIR=
LINKEDIN_PROFILE_DIR=
JOBRIGHT_PROFILE_DIR=

# --- Web search: combination outreach discovery (optional) ---
# Also powers POST /api/person-web-search (quoted-name + optional company/title queries).
# Google Programmable Search: https://developers.google.com/custom-search/v1/overview
# Create a Programmable Search Engine and use its "cx" id below.
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# Bing Web Search (Azure): https://learn.microsoft.com/en-us/bing/search-apis/bing-web-search/overview
# BING_SEARCH_KEY=

# --- Optional whoiswhat agent (recruiter / HM context) ---
# Point at the other repo root and the module that implements enrich_contacts.
# WHOISWHAT_AGENT_PATH=C:\path\to\whoiswhat
# WHOISWHAT_ENRICH_MODULE=whoiswhat.enrich
# WHOISWHAT_ENRICH_CALLABLE=enrich_contacts

# --- Contact Advisor stack (Meeting Advisor + people-intel) ---
# Full setup: see README.md → "Contact Advisor + Meeting Advisor"
# Source repo: https://github.com/Matonte/contact-advisor
#
# meeting_advisor: base URL of the *advisor application only* (no trailing slash).
# Resume-agent calls POST {MEETING_ADVISOR_URL}{MEETING_ADVISOR_ADVISE_PATH} (default path /api/v1/advise).
# Pointing this at resume-agent (http://127.0.0.1:8000) will 404 unless you run the advisor on that server.
# Typical: flask_sample meeting_advisor on another port, e.g.:
# MEETING_ADVISOR_URL=http://127.0.0.1:5003
# That process also needs Contact Advisor :5000 and WhoIsHoss :5002 (see that repo’s README).
#
# Contact Advisor people-intel (resume-agent → flask_sample POST /api/v1/people-intel).
# Prefer CONTACT_ADVISOR_SERVICE_URL; WHOISWHAT_SERVICE_URL is a deprecated alias.
# CONTACT_ADVISOR_SERVICE_URL=http://127.0.0.1:5000
# WHOISWHAT_SERVICE_URL=http://127.0.0.1:5000
# WHOISWHAT_PEOPLE_INTEL_PATH=/api/v1/people-intel
# Smoke-test from repo root: python scripts/check_meeting_advisor_stack.py
# POST /api/person-profile-bundle — optional web search + people-intel + Meeting Advisor (K + HOSS + tactical JSON).
# Optional: send the *browser* (GET /meeting-advisor) to another host’s HTML UI.
# When unset, Resume Agent serves its own advisor page; API calls still use MEETING_ADVISOR_URL.
# MEETING_ADVISOR_UI_URL=http://127.0.0.1:5003
